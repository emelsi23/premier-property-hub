@page "/Apartamentos/Index"
@using ApartamentosRenta.Services
@model ApartamentosRenta.Pages.Apartamentos.IndexModel
@{
    ViewData["Title"] = "Browse rentals";
    var filters = Model.Filters;
}

<div class="catalog-page">
    <section class="catalog-hero">
        <div class="catalog-hero-glow" aria-hidden="true"></div>
        <div class="catalog-hero-inner">
            <p class="catalog-eyebrow">Premier Property Hub · By Zillow</p>
            <h1 class="catalog-hero-title">Find a verified rental you can trust</h1>
            <p class="catalog-hero-lead">
                Browse @Model.TotalAvailable curated homes across top markets. Every listing includes a secure visit booking,
                official lease documentation, and transparent deposit handling.
            </p>
            <div class="catalog-hero-stats">
                <div class="catalog-stat">
                    <strong>@Model.TotalAvailable</strong>
                    <span>Available homes</span>
                </div>
                <div class="catalog-stat">
                    <strong>@Model.StateOptions.Count</strong>
                    <span>States covered</span>
                </div>
                <div class="catalog-stat">
                    <strong>100%</strong>
                    <span>Verified process</span>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.WhatsAppUrl))
            {
                <div class="catalog-whatsapp-banner">
                    <div class="catalog-whatsapp-copy">
                        <p class="catalog-whatsapp-eyebrow">Need help choosing?</p>
                        <p class="catalog-whatsapp-lead">Chat with a licensed agent on WhatsApp — fast replies, no obligation.</p>
                    </div>
                    <a href="@Model.WhatsAppUrl" class="catalog-whatsapp-btn" target="_blank" rel="noopener noreferrer">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.881 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                        <span>WhatsApp @Model.WhatsAppDisplay</span>
                    </a>
                </div>
            }
        </div>
    </section>

    <section class="catalog-filters-wrap">
        <form method="get" class="catalog-filters card border-0 shadow-sm">
            <div class="row g-3 align-items-end">
                <div class="col-lg-4">
                    <label class="form-label catalog-filter-label" for="searchQuery">Search</label>
                    <input type="search" id="searchQuery" name="Filters.Query" value="@filters.Query"
                           class="form-control catalog-input" placeholder="City, address, amenities…" />
                </div>
                <div class="col-md-6 col-lg-2">
                    <label class="form-label catalog-filter-label" for="filterState">State</label>
                    <select id="filterState" name="Filters.State" class="form-select catalog-input">
                        <option value="">All states</option>
                        @foreach (var state in Model.StateOptions)
                        {
                            <option value="@state.Code" selected="@(filters.State == state.Code ? "selected" : null)">
                                @state.Name (@state.Count)
                            </option>
                        }
                    </select>
                </div>
                <div class="col-6 col-md-3 col-lg-1">
                    <label class="form-label catalog-filter-label" for="filterBeds">Beds</label>
                    <select id="filterBeds" name="Filters.Bedrooms" class="form-select catalog-input">
                        <option value="">Any</option>
                        @for (var b = 1; b <= 4; b++)
                        {
                            <option value="@b" selected="@(filters.Bedrooms == b ? "selected" : null)">@b+</option>
                        }
                    </select>
                </div>
                <div class="col-6 col-md-3 col-lg-2">
                    <label class="form-label catalog-filter-label" for="filterMinRent">Min rent</label>
                    <input type="number" id="filterMinRent" name="Filters.MinRent" value="@filters.MinRent"
                           class="form-control catalog-input" min="0" step="50" placeholder="@Model.MinListingRent.ToString("N0")" />
                </div>
                <div class="col-6 col-md-3 col-lg-2">
                    <label class="form-label catalog-filter-label" for="filterMaxRent">Max rent</label>
                    <input type="number" id="filterMaxRent" name="Filters.MaxRent" value="@filters.MaxRent"
                           class="form-control catalog-input" min="0" step="50" placeholder="@Model.MaxListingRent.ToString("N0")" />
                </div>
                <div class="col-6 col-md-3 col-lg-1">
                    <label class="form-label catalog-filter-label" for="filterSort">Sort</label>
                    <select id="filterSort" name="Filters.Sort" class="form-select catalog-input">
                        <option value="price-asc" selected="@(filters.Sort == "price-asc" ? "selected" : null)">Price ↑</option>
                        <option value="price-desc" selected="@(filters.Sort == "price-desc" ? "selected" : null)">Price ↓</option>
                        <option value="beds-desc" selected="@(filters.Sort == "beds-desc" ? "selected" : null)">Beds</option>
                        <option value="newest" selected="@(filters.Sort == "newest" ? "selected" : null)">Newest</option>
                    </select>
                </div>
            </div>
            <div class="catalog-filter-actions">
                <button type="submit" class="btn btn-primary catalog-btn-search">Search listings</button>
                <a asp-page="/Apartamentos/Index" class="btn btn-outline-secondary">Clear filters</a>
                <span class="catalog-results-count">@Model.Listings.Count result@(Model.Listings.Count == 1 ? "" : "s")</span>
            </div>
        </form>
    </section>

    @if (!Model.Listings.Any())
    {
        <div class="catalog-empty card border-0 shadow-sm">
            <h2>No listings match your search</h2>
            <p>Try a different state, price range, or search term.</p>
            <a asp-page="/Apartamentos/Index" class="btn btn-primary">View all rentals</a>
        </div>
    }
    else
    {
        <section class="catalog-grid" aria-label="Rental listings">
            @foreach (var item in Model.Listings)
            {
                <article class="catalog-card">
                    <a href="@item.ScheduleUrl" class="catalog-card-media">
                        @if (!string.IsNullOrWhiteSpace(item.PhotoUrl))
                        {
                            <img src="@item.PhotoUrl" alt="@item.Titulo" loading="lazy" />
                        }
                        else
                        {
                            <div class="catalog-card-placeholder">No photo</div>
                        }
                        <span class="catalog-card-badge">@item.StateName</span>
                        <span class="catalog-card-verified">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 16.17 4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                            Verified
                        </span>
                    </a>
                    <div class="catalog-card-body">
                        <p class="catalog-card-location">@item.CityLabel</p>
                        <h2 class="catalog-card-title">
                            <a href="@item.ScheduleUrl">@item.Titulo</a>
                        </h2>
                        <p class="catalog-card-address">@item.Direccion</p>
                        <p class="catalog-card-price">$@item.PrecioMensual.ToString("N0")<span>/mo</span></p>
                        <div class="catalog-card-stats">
                            <span>@item.Habitaciones bd</span>
                            <span>@item.Banos ba</span>
                            <span>@item.MetrosCuadrados.ToString("N0") sq ft</span>
                        </div>
                        @if (item.AmenityTags.Any())
                        {
                            <div class="catalog-card-tags">
                                @foreach (var tag in item.AmenityTags)
                                {
                                    <span>@tag</span>
                                }
                            </div>
                        }
                        <div class="catalog-card-footer">
                            <span class="catalog-deposit-note">Visit deposit from $@item.DepositAmount.ToString("N0")</span>
                            <a href="@item.ScheduleUrl" class="btn btn-primary catalog-card-cta">Schedule visit</a>
                        </div>
                    </div>
                </article>
            }
        </section>
    }

    <section class="catalog-trust" aria-label="Why renters trust us">
        <div class="catalog-trust-header">
            <p class="catalog-eyebrow">Trusted rental process</p>
            <h2>Built for confidence at every step</h2>
            <p>From your first search to signed documentation, Premier Property Hub keeps the process professional, secure, and transparent.</p>
        </div>
        <div class="catalog-trust-grid">
            <article class="catalog-trust-card">
                <div class="catalog-trust-icon catalog-trust-icon-blue" aria-hidden="true">🛡️</div>
                <h3>Verified listings</h3>
                <p>Every property is reviewed before publication. No spam, no fake ads — only real homes ready to tour.</p>
            </article>
            <article class="catalog-trust-card">
                <div class="catalog-trust-icon catalog-trust-icon-green" aria-hidden="true">✓</div>
                <h3>Secure visit booking</h3>
                <p>Schedule a certified 30-minute visit with a refundable deposit and clear next steps.</p>
            </article>
            <article class="catalog-trust-card">
                <div class="catalog-trust-icon catalog-trust-icon-gold" aria-hidden="true">📜</div>
                <h3>Official lease contracts</h3>
                <p>Digital lease agreements tailored to each property with e-signature support.</p>
            </article>
            <article class="catalog-trust-card">
                <div class="catalog-trust-icon catalog-trust-icon-purple" aria-hidden="true">🏷️</div>
                <h3>Stamps &amp; seals</h3>
                <p>Official documentation packages available when required — stamps, seals, or both.</p>
            </article>
            <article class="catalog-trust-card">
                <div class="catalog-trust-icon catalog-trust-icon-teal" aria-hidden="true">🔒</div>
                <h3>Encrypted payments</h3>
                <p>Deposit handling via Zelle with payment proof upload and admin verification.</p>
            </article>
            <article class="catalog-trust-card">
                <div class="catalog-trust-icon catalog-trust-icon-navy" aria-hidden="true">👤</div>
                <h3>Licensed support</h3>
                <p>Our team confirms appointments by phone or <a href="@Model.WhatsAppUrl" class="catalog-inline-wa" target="_blank" rel="noopener noreferrer">WhatsApp</a> once your deposit is approved.</p>
            </article>
        </div>

        <div class="catalog-seals-strip">
            <div class="catalog-seal">
                <span class="catalog-seal-ring">PREMIER</span>
                <small>Property Hub</small>
            </div>
            <div class="catalog-seal">
                <span class="catalog-seal-ring">ZILLOW</span>
                <small>Partner network</small>
            </div>
            <div class="catalog-seal">
                <span class="catalog-seal-ring">SSL</span>
                <small>Secure browsing</small>
            </div>
            <div class="catalog-seal">
                <span class="catalog-seal-ring">OFFICIAL</span>
                <small>Lease &amp; stamps</small>
            </div>
            <div class="catalog-seal">
                <span class="catalog-seal-ring">REFUND</span>
                <small>Visit deposit</small>
            </div>
        </div>
    </section>
</div>
