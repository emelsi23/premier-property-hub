@model ApartamentosRenta.Pages.Admin.PropertyInput

<div class="row g-3">
    <div class="col-md-8">
        <label asp-for="Titulo" class="form-label"></label>
        <input asp-for="Titulo" class="form-control" />
        <span asp-validation-for="Titulo" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Ciudad" class="form-label"></label>
        <input asp-for="Ciudad" class="form-control" />
        <span asp-validation-for="Ciudad" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Direccion" class="form-label"></label>
        <input asp-for="Direccion" class="form-control" placeholder="e.g. 250 Reforma Ave, Juarez District" />
        <div class="form-text">The address is used to generate the link: /property/250-reforma-ave-juarez-district</div>
        <span asp-validation-for="Direccion" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Descripcion" class="form-label"></label>
        <textarea asp-for="Descripcion" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Descripcion" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="PrecioMensual" class="form-label"></label>
        <input asp-for="PrecioMensual" class="form-control" type="number" step="100" />
        <span asp-validation-for="PrecioMensual" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Habitaciones" class="form-label"></label>
        <input asp-for="Habitaciones" class="form-control" type="number" />
    </div>
    <div class="col-md-3">
        <label asp-for="Banos" class="form-label"></label>
        <input asp-for="Banos" class="form-control" type="number" />
    </div>
    <div class="col-md-3">
        <label asp-for="MetrosCuadrados" class="form-label"></label>
        <input asp-for="MetrosCuadrados" class="form-control" type="number" step="0.1" />
    </div>
    <div class="col-12">
        <label asp-for="FotosUrls" class="form-label"></label>
        <textarea asp-for="FotosUrls" class="form-control font-monospace" rows="5" placeholder="https://...&#10;https://..."></textarea>
        <div class="form-text">Paste one URL per line. Clients will see all photos on the property page.</div>
        <span asp-validation-for="FotosUrls" class="text-danger"></span>
    </div>
    <div class="col-md-8">
        <label asp-for="Amenidades" class="form-label"></label>
        <input asp-for="Amenidades" class="form-control" placeholder="Parking, Gym, 24h Security" />
    </div>
    <div class="col-md-4 d-flex align-items-end">
        <div class="form-check mb-2">
            <input asp-for="Disponible" class="form-check-input" type="checkbox" />
            <label asp-for="Disponible" class="form-check-label"></label>
        </div>
    </div>
    <div class="col-12">
        <hr class="my-1" />
        <h2 class="h6 text-muted mb-3">Public page display</h2>
        <p class="form-text">Choose what clients see on <code>/property/…</code> and which language to use.</p>
    </div>
    <div class="col-md-4">
        <div class="form-check">
            <input asp-for="MostrarAplicacionPublica" class="form-check-input" type="checkbox" />
            <label asp-for="MostrarAplicacionPublica" class="form-check-label"></label>
        </div>
    </div>
    <div class="col-md-4">
        <div class="form-check">
            <input asp-for="MostrarContratoPublico" class="form-check-input" type="checkbox" />
            <label asp-for="MostrarContratoPublico" class="form-check-label"></label>
        </div>
    </div>
    <div class="col-md-4">
        <div class="form-check">
            <input asp-for="MostrarStampillasPublico" class="form-check-input" type="checkbox" />
            <label asp-for="MostrarStampillasPublico" class="form-check-label"></label>
        </div>
    </div>
    <div class="col-md-6">
        <label asp-for="IdiomaPublico" class="form-label"></label>
        <select asp-for="IdiomaPublico" class="form-select" asp-items="Html.GetEnumSelectList<ApartamentosRenta.Models.PropertyPublicLanguage>()"></select>
        <div class="form-text">Bilingual shows an English / Español switcher on the public page.</div>
    </div>
    <div class="col-12">
        <hr class="my-1" />
        <h2 class="h6 text-muted mb-3">Zelle deposit (shown to clients after approval)</h2>
    </div>
    <div class="col-md-4">
        <label class="form-label">Visit deposit</label>
        <p class="form-control-plaintext fw-semibold mb-0">$150</p>
        <input type="hidden" asp-for="DepositAmount" />
        <div class="form-text">Fixed for all properties (contract &amp; Zelle).</div>
    </div>
    <div class="col-md-4">
        <label asp-for="ZelleDisplayName" class="form-label"></label>
        <input asp-for="ZelleDisplayName" class="form-control" placeholder="Premier Property Hub" />
    </div>
    <div class="col-md-4">
        <label asp-for="ZelleContact" class="form-label"></label>
        <input asp-for="ZelleContact" class="form-control" placeholder="payments@email.com" />
        <div class="form-text">Zelle email or mobile number.</div>
    </div>
    <div class="col-12">
        <hr class="my-1" />
        <h2 class="h6 text-muted mb-3">Lease contract (per property)</h2>
        <p class="form-text">Use placeholders like <code>{{MonthlyRent}}</code>, <code>{{SecurityDeposit}}</code>, <code>{{PropertyTitle}}</code>, <code>{{Address}}</code>, <code>{{VisitDeposit}}</code>. Amounts are calculated from monthly rent when clients view the contract.</p>
    </div>
    <div class="col-md-6">
        <label asp-for="ContractTitle" class="form-label"></label>
        <input asp-for="ContractTitle" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="ContractSubtitle" class="form-label"></label>
        <input asp-for="ContractSubtitle" class="form-control" />
    </div>
    <div class="col-12">
        <label asp-for="ContractNoticeHtml" class="form-label"></label>
        <textarea asp-for="ContractNoticeHtml" class="form-control font-monospace" rows="3"></textarea>
    </div>
    <div class="col-12">
        <label asp-for="ContractBodyHtml" class="form-label"></label>
        <textarea asp-for="ContractBodyHtml" class="form-control font-monospace" rows="12"></textarea>
    </div>
    <div class="col-12">
        <hr class="my-1" />
        <h2 class="h6 text-muted mb-3">Lease contract — Spanish (optional)</h2>
        <p class="form-text">Leave blank to use the English version when Spanish is selected.</p>
    </div>
    <div class="col-md-6">
        <label asp-for="ContractTitleEs" class="form-label"></label>
        <input asp-for="ContractTitleEs" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="ContractSubtitleEs" class="form-label"></label>
        <input asp-for="ContractSubtitleEs" class="form-control" />
    </div>
    <div class="col-12">
        <label asp-for="ContractNoticeHtmlEs" class="form-label"></label>
        <textarea asp-for="ContractNoticeHtmlEs" class="form-control font-monospace" rows="3"></textarea>
    </div>
    <div class="col-12">
        <label asp-for="ContractBodyHtmlEs" class="form-label"></label>
        <textarea asp-for="ContractBodyHtmlEs" class="form-control font-monospace" rows="12"></textarea>
    </div>
    <div class="col-12">
        <hr class="my-1" />
        <h2 class="h6 text-muted mb-3">Stamps &amp; seals agreement (per property)</h2>
        <p class="form-text">Fixed fees: stamps <strong>$245</strong> + seals <strong>$245</strong> = <strong>$490</strong>. Placeholders: <code>{{StampsAmount}}</code>, <code>{{SealsAmount}}</code>, <code>{{TotalAmount}}</code>, <code>{{PropertyTitle}}</code>, <code>{{ZelleContact}}</code>.</p>
    </div>
    <div class="col-md-6">
        <label asp-for="StampSealTitle" class="form-label"></label>
        <input asp-for="StampSealTitle" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="StampSealSubtitle" class="form-label"></label>
        <input asp-for="StampSealSubtitle" class="form-control" />
    </div>
    <div class="col-12">
        <label asp-for="StampSealNoticeHtml" class="form-label"></label>
        <textarea asp-for="StampSealNoticeHtml" class="form-control font-monospace" rows="3"></textarea>
    </div>
    <div class="col-12">
        <label asp-for="StampSealBodyHtml" class="form-label"></label>
        <textarea asp-for="StampSealBodyHtml" class="form-control font-monospace" rows="10"></textarea>
    </div>
    <div class="col-12">
        <hr class="my-1" />
        <h2 class="h6 text-muted mb-3">Stamps &amp; seals — Spanish (optional)</h2>
    </div>
    <div class="col-md-6">
        <label asp-for="StampSealTitleEs" class="form-label"></label>
        <input asp-for="StampSealTitleEs" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="StampSealSubtitleEs" class="form-label"></label>
        <input asp-for="StampSealSubtitleEs" class="form-control" />
    </div>
    <div class="col-12">
        <label asp-for="StampSealNoticeHtmlEs" class="form-label"></label>
        <textarea asp-for="StampSealNoticeHtmlEs" class="form-control font-monospace" rows="3"></textarea>
    </div>
    <div class="col-12">
        <label asp-for="StampSealBodyHtmlEs" class="form-label"></label>
        <textarea asp-for="StampSealBodyHtmlEs" class="form-control font-monospace" rows="10"></textarea>
    </div>
</div>
