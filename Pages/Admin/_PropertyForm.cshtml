@model ApartamentosRenta.Pages.Admin.PropertyInput

<div class="row g-3">
    <div class="col-md-8">
        <label asp-for="Titulo" class="form-label"></label>
        <input asp-for="Titulo" class="form-control" />
        <span asp-validation-for="Titulo" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Ciudad" class="form-label"></label>
        <input asp-for="Ciudad" class="form-control" />
        <span asp-validation-for="Ciudad" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Direccion" class="form-label"></label>
        <input asp-for="Direccion" class="form-control" placeholder="e.g. 250 Reforma Ave, Juarez District" />
        <div class="form-text">The address is used to generate the link: /property/250-reforma-ave-juarez-district</div>
        <span asp-validation-for="Direccion" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Descripcion" class="form-label"></label>
        <textarea asp-for="Descripcion" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Descripcion" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="PrecioMensual" class="form-label"></label>
        <input asp-for="PrecioMensual" class="form-control" type="number" step="100" />
        <span asp-validation-for="PrecioMensual" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Habitaciones" class="form-label"></label>
        <input asp-for="Habitaciones" class="form-control" type="number" />
    </div>
    <div class="col-md-3">
        <label asp-for="Banos" class="form-label"></label>
        <input asp-for="Banos" class="form-control" type="number" />
    </div>
    <div class="col-md-3">
        <label asp-for="MetrosCuadrados" class="form-label"></label>
        <input asp-for="MetrosCuadrados" class="form-control" type="number" step="0.1" />
    </div>
    <div class="col-12">
        <label asp-for="FotosUrls" class="form-label"></label>
        <textarea asp-for="FotosUrls" class="form-control font-monospace" rows="5" placeholder="https://...&#10;https://..."></textarea>
        <div class="form-text">Paste one URL per line. Clients will see all photos on the property page.</div>
        <span asp-validation-for="FotosUrls" class="text-danger"></span>
    </div>
    <div class="col-md-8">
        <label asp-for="Amenidades" class="form-label"></label>
        <input asp-for="Amenidades" class="form-control" placeholder="Parking, Gym, 24h Security" />
    </div>
    <div class="col-md-4 d-flex align-items-end">
        <div class="form-check mb-2">
            <input asp-for="Disponible" class="form-check-input" type="checkbox" />
            <label asp-for="Disponible" class="form-check-label"></label>
        </div>
    </div>
    <div class="col-12">
        <hr class="my-1" />
        <h2 class="h6 text-muted mb-3">Zelle deposit (shown to clients after approval)</h2>
    </div>
    <div class="col-md-4">
        <label asp-for="DepositAmount" class="form-label"></label>
        <input asp-for="DepositAmount" class="form-control" type="number" step="1" min="0" />
        <span asp-validation-for="DepositAmount" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="ZelleDisplayName" class="form-label"></label>
        <input asp-for="ZelleDisplayName" class="form-control" placeholder="Premier Property Hub" />
    </div>
    <div class="col-md-4">
        <label asp-for="ZelleContact" class="form-label"></label>
        <input asp-for="ZelleContact" class="form-control" placeholder="payments@email.com" />
        <div class="form-text">Zelle email or mobile number.</div>
    </div>
    <div class="col-12">
        <hr class="my-1" />
        <h2 class="h6 text-muted mb-3">Lease contract (per property)</h2>
        <p class="form-text">Use placeholders like <code>{{MonthlyRent}}</code>, <code>{{SecurityDeposit}}</code>, <code>{{PropertyTitle}}</code>, <code>{{Address}}</code>, <code>{{VisitDeposit}}</code>. Amounts are calculated from monthly rent when clients view the contract.</p>
    </div>
    <div class="col-md-6">
        <label asp-for="ContractTitle" class="form-label"></label>
        <input asp-for="ContractTitle" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="ContractSubtitle" class="form-label"></label>
        <input asp-for="ContractSubtitle" class="form-control" />
    </div>
    <div class="col-12">
        <label asp-for="ContractNoticeHtml" class="form-label"></label>
        <textarea asp-for="ContractNoticeHtml" class="form-control font-monospace" rows="3"></textarea>
    </div>
    <div class="col-12">
        <label asp-for="ContractBodyHtml" class="form-label"></label>
        <textarea asp-for="ContractBodyHtml" class="form-control font-monospace" rows="12"></textarea>
    </div>
</div>
