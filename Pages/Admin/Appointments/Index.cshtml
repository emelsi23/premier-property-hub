@page
@using ApartamentosRenta.Models
@using ApartamentosRenta.Services
@model ApartamentosRenta.Pages.Admin.Appointments.IndexModel
@{
    ViewData["Title"] = "Appointments";
    static string YesNo(bool value) => value ? "Yes" : "No";
    static string MetodoLabel(MetodoPagoCita? metodo) => metodo switch
    {
        MetodoPagoCita.Zelle => "Zelle",
        MetodoPagoCita.ApplePay => "Apple Pay",
        MetodoPagoCita.Efectivo => "Cash",
        _ => "—"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Visit appointments</h1>
        <p class="text-muted mb-0">Review applications, payment proofs, and confirm visits.</p>
    </div>
    <a asp-page="/Admin/Index" class="btn btn-outline-secondary">← Properties</a>
</div>

@if (!Model.Appointments.Any())
{
    <div class="alert alert-info">No appointments yet. Share a property link via WhatsApp to get started.</div>
}
else
{
    <div class="table-responsive card shadow-sm border-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Client</th>
                    <th>Property</th>
                    <th>Visit</th>
                    <th>Payment</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var appointment in Model.Appointments)
                {
                    var detailsId = $"details-{appointment.Id}";
                    <tr>
                        <td>
                            <strong>@appointment.NombreCompleto</strong><br />
                            <a href="mailto:@appointment.Email" class="small">@appointment.Email</a><br />
                            <a href="https://wa.me/@(new string(appointment.Telefono.Where(char.IsDigit).ToArray()))" target="_blank" class="small">@appointment.Telefono</a><br />
                            <span class="small text-muted">SSN: @appointment.SsnItin · DOB: @appointment.FechaNacimiento.ToString("MM/dd/yyyy")</span>
                        </td>
                        <td>
                            @appointment.Propiedad.Titulo<br />
                            <span class="small text-muted">@appointment.Propiedad.Direccion</span>
                        </td>
                        <td>
                            @appointment.FechaHora.ToString("MM/dd/yyyy HH:mm")
                            @if (!string.IsNullOrWhiteSpace(appointment.CodigoPostal))
                            {
                                <div class="small text-muted">Zip: @appointment.CodigoPostal</div>
                            }
                        </td>
                        <td>
                            @if (appointment.PaymentProofData is { Length: > 0 })
                            {
                                <a asp-page-handler="PaymentProof" asp-route-id="@appointment.Id" target="_blank" class="d-inline-block">
                                    <img src="@Url.Page(null, "PaymentProof", new { id = appointment.Id })"
                                         alt="Payment proof"
                                         class="payment-proof-thumb" />
                                </a>
                                @if (appointment.PaymentProofUploadedAt.HasValue)
                                {
                                    <div class="small text-muted">@appointment.PaymentProofUploadedAt.Value.ToString("MM/dd/yyyy HH:mm") UTC</div>
                                }
                            }
                            else
                            {
                                <span class="small text-muted">Deposit: $@VisitDepositSettings.Amount.ToString("N0")</span>
                            }
                            @if (appointment.MetodoPago.HasValue)
                            {
                                <div class="small text-muted">@MetodoLabel(appointment.MetodoPago)</div>
                            }
                        </td>
                        <td>
                            @switch (appointment.Estado)
                            {
                                case EstadoCita.Pendiente:
                                case EstadoCita.EsperandoDeposito:
                                    <span class="badge bg-warning text-dark">Awaiting deposit</span>
                                    break;
                                case EstadoCita.EsperandoConfirmacion:
                                    <span class="badge bg-info text-dark">Awaiting confirmation</span>
                                    break;
                                case EstadoCita.Confirmada:
                                    <span class="badge bg-success">Confirmed</span>
                                    break;
                                case EstadoCita.Cancelada:
                                    <span class="badge bg-secondary">Cancelled</span>
                                    break;
                            }
                        </td>
                        <td class="text-end">
                            <button type="button" class="btn btn-sm btn-outline-primary mb-1" data-bs-toggle="collapse" data-bs-target="#@detailsId">
                                Details
                            </button>
                            @if (appointment.Estado == EstadoCita.EsperandoConfirmacion)
                            {
                                <form method="post" asp-page-handler="Confirm" asp-route-id="@appointment.Id" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-success">Confirm visit</button>
                                </form>
                            }
                            @if (appointment.Estado is not EstadoCita.Confirmada and not EstadoCita.Cancelada)
                            {
                                <form method="post" asp-page-handler="Cancel" asp-route-id="@appointment.Id" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Cancel</button>
                                </form>
                            }
                        </td>
                    </tr>
                    <tr class="collapse-row">
                        <td colspan="6" class="p-0 border-0">
                            <div class="collapse" id="@detailsId">
                                <div class="appointment-details-panel">
                                    <div class="row g-3 small">
                                        <div class="col-md-4"><strong>U.S. citizen</strong><br />@YesNo(appointment.EsCiudadanoAmericano)</div>
                                        <div class="col-md-4"><strong>Occupants</strong><br />@appointment.PersonasEnUnidad</div>
                                        <div class="col-md-4"><strong>Lease length</strong><br />@(appointment.DuracionContratoDeseada ?? "—")</div>
                                        <div class="col-md-4"><strong>Earliest move-in</strong><br />@(appointment.FechaMudanzaTemprana?.ToString("MM/dd/yyyy") ?? "—")</div>
                                        <div class="col-md-4"><strong>Smokes</strong><br />@YesNo(appointment.Fuma)</div>
                                        <div class="col-md-4"><strong>Pets</strong><br />@YesNo(appointment.TieneMascotas)</div>
                                        <div class="col-md-4"><strong>Employed</strong><br />@YesNo(appointment.EmpleadoActualmente)</div>
                                        <div class="col-md-4"><strong>Employer</strong><br />@(appointment.NombreCompania ?? "—")</div>
                                        <div class="col-md-4"><strong>Income</strong><br />@(appointment.Salario.HasValue ? $"${appointment.Salario:N0}" : "—")</div>
                                        <div class="col-md-4"><strong>Available funds</strong><br />@(appointment.DisponibleParaAsegurar.HasValue ? $"${appointment.DisponibleParaAsegurar:N0}" : "—")</div>
                                        <div class="col-md-4"><strong>Accepts reservation deposit</strong><br />@YesNo(appointment.AceptaDepositoReserva)</div>
                                        <div class="col-md-4"><strong>Will pay certified visit</strong><br />@YesNo(appointment.PagaraCitaCertificada)</div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
