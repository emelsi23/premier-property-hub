@page
@model ApartamentosRenta.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "My properties";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
        <h1 class="h3 mb-1">My properties</h1>
        <p class="text-muted mb-0">Copy the link and send it to clients via WhatsApp.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="/Admin/Appointments/Index" class="btn btn-outline-primary">View appointments</a>
        <a asp-page="Create" class="btn btn-primary">+ New property</a>
    </div>
</div>

@if (!Model.Propiedades.Any())
{
    <div class="alert alert-info">You don't have any properties yet. Create one to get your WhatsApp link.</div>
}
else
{
    <div class="vstack gap-3">
        @foreach (var prop in Model.Propiedades)
        {
            var link = Model.BuildLink(prop.Slug);
            var pendingAppointments = prop.Citas.Count(c =>
                c.Estado == ApartamentosRenta.Models.EstadoCita.Pendiente
                || c.Estado == ApartamentosRenta.Models.EstadoCita.EsperandoDeposito
                || c.Estado == ApartamentosRenta.Models.EstadoCita.EsperandoConfirmacion);
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="row g-3 align-items-center">
                        <div class="col-md-3">
                            @if (prop.Fotos.Any())
                            {
                                <img src="@prop.Fotos.OrderBy(f => f.Orden).First().Url" alt="@prop.Titulo" class="img-fluid rounded admin-thumb" />
                            }
                        </div>
                        <div class="col-md-5">
                            <h2 class="h5 mb-1">@prop.Titulo</h2>
                            <p class="text-muted small mb-2">@prop.Direccion, @prop.Ciudad</p>
                            <p class="mb-0 fw-semibold text-primary">$@prop.PrecioMensual.ToString("N0")/mo</p>
                            @if (pendingAppointments > 0)
                            {
                                <span class="badge bg-warning text-dark mt-2">@pendingAppointments pending appointment(s)</span>
                            }
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-muted mb-1">WhatsApp link</label>
                            <div class="input-group input-group-sm mb-2">
                                <input type="text" class="form-control font-monospace wa-link" value="@link" readonly />
                                <button type="button" class="btn btn-outline-secondary btn-copy" data-link="@link">Copy</button>
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                <a href="/property/@prop.Slug" target="_blank" class="btn btn-sm btn-outline-primary">View page</a>
                                <a href="/property/@prop.Slug/contract" target="_blank" class="btn btn-sm btn-outline-primary">Lease</a>
                                <a href="/property/@prop.Slug/stamps" target="_blank" class="btn btn-sm btn-outline-primary">Stamps</a>
                                <a asp-page="Edit" asp-route-id="@prop.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <a asp-page="Delete" asp-route-id="@prop.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        document.querySelectorAll('.btn-copy').forEach(btn => {
            btn.addEventListener('click', async () => {
                const link = btn.dataset.link;
                await navigator.clipboard.writeText(link);
                const original = btn.textContent;
                btn.textContent = 'Copied!';
                setTimeout(() => btn.textContent = original, 1500);
            });
        });
    </script>
}
