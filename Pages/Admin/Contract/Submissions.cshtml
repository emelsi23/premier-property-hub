@page
@model ApartamentosRenta.Pages.Admin.Contract.SubmissionsModel
@{
    ViewData["Title"] = "Contract submissions";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
        <h1 class="h3 mb-1">Contract submissions</h1>
        <p class="text-muted mb-0">Signatures and change requests from clients.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="Edit" class="btn btn-outline-primary">Edit contract</a>
        <a asp-page="/Admin/Index" class="btn btn-outline-secondary">← Properties</a>
    </div>
</div>

@if (!Model.Submissions.Any())
{
    <div class="alert alert-info">No submissions yet.</div>
}
else
{
    <div class="table-responsive card shadow-sm border-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Client</th>
                    <th>Type</th>
                    <th>Signature</th>
                    <th>Proposed changes</th>
                    <th>Submitted</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Submissions)
                {
                    <tr>
                        <td>
                            <strong>@item.TenantName</strong><br />
                            <a href="mailto:@item.TenantEmail" class="small">@item.TenantEmail</a>
                            @if (!string.IsNullOrWhiteSpace(item.TenantPhone))
                            {
                                <br /><span class="small text-muted">@item.TenantPhone</span>
                            }
                        </td>
                        <td>
                            @if (item.SubmissionType == ApartamentosRenta.Models.ContractSubmissionType.Signature)
                            {
                                <span class="badge bg-success">Signature</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark">Change request</span>
                            }
                        </td>
                        <td>
                            @if (item.SignatureImageData is { Length: > 0 })
                            {
                                <a asp-page-handler="Signature" asp-route-id="@item.Id" target="_blank">
                                    <img src="@Url.Page(null, "Signature", new { id = item.Id })"
                                         alt="Signature"
                                         class="payment-proof-thumb" />
                                </a>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td class="small" style="max-width: 280px; white-space: pre-wrap;">@(item.ProposedChanges ?? "—")</td>
                        <td class="small text-muted">@item.SubmittedAt.ToString("MM/dd/yyyy HH:mm") UTC</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
