@page
@model ApartamentosRenta.Pages.Admin.Contract.EditModel
@{
    ViewData["Title"] = "Edit lease contract";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
        <h1 class="h3 mb-1">Edit lease contract</h1>
        <p class="text-muted mb-0">Changes appear on the public <a href="/contract" target="_blank">/contract</a> page.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page="Submissions" class="btn btn-outline-primary">View submissions</a>
        <a asp-page="/Admin/Index" class="btn btn-outline-secondary">← Properties</a>
    </div>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success">@success</div>
}

<form method="post" class="card shadow-sm border-0">
    <div class="card-body vstack gap-3">
        <div>
            <label asp-for="Input.Title" class="form-label"></label>
            <input asp-for="Input.Title" class="form-control" />
            <span asp-validation-for="Input.Title" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="Input.Subtitle" class="form-label"></label>
            <input asp-for="Input.Subtitle" class="form-control" />
            <span asp-validation-for="Input.Subtitle" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="Input.NoticeHtml" class="form-label">Notice banner (HTML)</label>
            <textarea asp-for="Input.NoticeHtml" class="form-control font-monospace" rows="4"></textarea>
            <span asp-validation-for="Input.NoticeHtml" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="Input.BodyHtml" class="form-label">Contract body (HTML)</label>
            <div class="form-text mb-2">Use <code>&lt;section class="contract-section"&gt;</code> blocks. Clients sign at the bottom of the public page.</div>
            <textarea asp-for="Input.BodyHtml" class="form-control font-monospace" rows="24"></textarea>
            <span asp-validation-for="Input.BodyHtml" class="text-danger"></span>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save contract</button>
            <a href="/contract" target="_blank" class="btn btn-outline-secondary">Preview</a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
