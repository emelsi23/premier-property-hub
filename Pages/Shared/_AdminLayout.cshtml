@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    var isProperties = currentPage == "/Admin/Index" || currentPage.StartsWith("/Admin/Create", StringComparison.Ordinal) || currentPage.StartsWith("/Admin/Edit", StringComparison.Ordinal);
    var isAppointments = currentPage.StartsWith("/Admin/Appointments", StringComparison.OrdinalIgnoreCase);
    var isContract = currentPage.StartsWith("/Admin/Contract", StringComparison.OrdinalIgnoreCase);
    var isStampSeals = currentPage.StartsWith("/Admin/StampSeals", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg bg-white border-bottom shadow-sm">
        <div class="container-xl">
            <a class="navbar-brand fw-bold" asp-page="/Admin/Index">Premier Property Hub</a>
            <div class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                <a class="nav-link @(isProperties ? "active fw-semibold" : "")" asp-page="/Admin/Index">Properties</a>
                <a class="nav-link @(isAppointments ? "active fw-semibold" : "")" asp-page="/Admin/Appointments/Index">Appointments</a>
                <a class="nav-link @(isContract ? "active fw-semibold" : "")" asp-page="/Admin/Contract/Submissions">Lease signs</a>
                <a class="nav-link @(isStampSeals ? "active fw-semibold" : "")" asp-page="/Admin/StampSeals/Submissions">Stamp signs</a>
                <form method="post" asp-page="/Admin/Logout" class="d-inline ms-lg-2">
                    <button type="submit" class="btn btn-sm btn-outline-secondary">Sign out</button>
                </form>
            </div>
        </div>
    </nav>
    <div class="container-xl py-4">
        @RenderBody()
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
