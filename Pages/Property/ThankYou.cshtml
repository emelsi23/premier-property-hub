@page "/property/{slug}/thank-you"
@model ApartamentosRenta.Pages.Property.ThankYouModel
@{
    ViewData["Title"] = "Request received";
}

<div class="cliente-page">
    <div class="cliente-card text-center py-5">
        <div class="success-icon mb-3">✓</div>
        <h1 class="property-title">All set!</h1>
        <p class="text-muted mb-4">
            We received your request to view <strong>@Model.PropertyTitle</strong><br />
            <span class="small">@Model.Address</span>
        </p>
        <p class="mb-0">We will contact you soon via WhatsApp to confirm your visit.</p>
    </div>
</div>
