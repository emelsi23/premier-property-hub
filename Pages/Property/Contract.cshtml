@page "/property/{slug}/contract"
@model ApartamentosRenta.Pages.Property.ContractModel
@{
    var propiedad = Model.Propiedad;
}

<article class="contract-page">
    <header class="contract-header">
        <p class="contract-brand">Premier Property Hub</p>
        <h1>@Model.RenderedTitle</h1>
        <p class="contract-subtitle">@Model.RenderedSubtitle</p>
        <p class="contract-effective">@propiedad.Titulo · $@propiedad.PrecioMensual.ToString("N0")/mo</p>
    </header>

    <div class="contract-notice">
        @Html.Raw(Model.RenderedNoticeHtml)
    </div>

    <div class="contract-amounts card border-0 shadow-sm mb-3">
        <div class="card-body">
            <h2 class="h6 text-muted mb-3">Amount summary (from monthly rent)</h2>
            <div class="row g-2 small">
                <div class="col-6 col-md-4"><span class="text-muted">Monthly rent</span><br /><strong>$@propiedad.PrecioMensual.ToString("N0")</strong></div>
                <div class="col-6 col-md-4"><span class="text-muted">Security deposit</span><br /><strong>$@propiedad.PrecioMensual.ToString("N0")</strong></div>
                <div class="col-6 col-md-4"><span class="text-muted">Visit deposit</span><br /><strong>$@((propiedad.DepositAmount > 0 ? propiedad.DepositAmount : propiedad.PrecioMensual).ToString("N0"))</strong></div>
            </div>
        </div>
    </div>

    <div class="contract-body">
        @Html.Raw(Model.RenderedBodyHtml)
    </div>

    <section class="contract-section contract-sign-panel" id="signPanel">
        <h2>Tenant signature</h2>
        <p class="mb-3">Review the agreement above, then sign or submit proposed changes.</p>

        <form id="contractSignForm" novalidate>
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label for="tenantName" class="form-label">Full legal name</label>
                    <input type="text" id="tenantName" class="form-control" maxlength="120" required />
                </div>
                <div class="col-md-6">
                    <label for="tenantEmail" class="form-label">Email</label>
                    <input type="email" id="tenantEmail" class="form-control" maxlength="256" required />
                </div>
                <div class="col-md-6">
                    <label for="tenantPhone" class="form-label">Phone (optional)</label>
                    <input type="tel" id="tenantPhone" class="form-control" maxlength="30" />
                </div>
            </div>

            <div class="contract-action-tabs mt-4">
                <label class="contract-action-tab">
                    <input type="radio" name="submitAction" value="sign" checked />
                    <span>Sign agreement</span>
                </label>
                <label class="contract-action-tab">
                    <input type="radio" name="submitAction" value="changes" />
                    <span>Request changes</span>
                </label>
            </div>

            <div id="signFields" class="mt-3">
                <label class="form-label">Draw your signature</label>
                <div class="signature-pad-wrap">
                    <canvas id="signaturePad" width="600" height="180" aria-label="Signature pad"></canvas>
                    <button type="button" class="btn btn-sm btn-outline-secondary signature-clear" id="clearSignature">Clear</button>
                </div>
                <label class="terms-check mt-3">
                    <input type="checkbox" id="agreeCheckbox" />
                    <span>I have read this agreement and agree to its terms.</span>
                </label>
            </div>

            <div id="changesFields" class="mt-3 d-none">
                <label for="proposedChanges" class="form-label">Proposed changes</label>
                <textarea id="proposedChanges" class="form-control" rows="5" maxlength="4000"
                          placeholder="Describe the clauses you would like to modify…"></textarea>
            </div>

            <div id="optionalChangesWrap" class="mt-3">
                <label for="optionalChanges" class="form-label">Additional notes (optional)</label>
                <textarea id="optionalChanges" class="form-control" rows="3" maxlength="4000"
                          placeholder="Optional comments to include with your signature…"></textarea>
            </div>

            <p id="signFormError" class="text-danger small d-none mt-2"></p>
            <button type="submit" class="btn btn-submit w-100 mt-3" id="submitContractBtn">Submit signature</button>
        </form>
    </section>

    <footer class="contract-footer">
        <p><a href="/property/@propiedad.Slug">← Back to property</a></p>
        <button type="button" class="btn btn-outline-secondary btn-sm mt-2" onclick="window.print()">Print contract</button>
    </footer>
</article>

<div id="contractSuccessModal" class="status-modal" aria-hidden="true">
    <div class="status-modal-backdrop"></div>
    <div class="status-modal-dialog is-success" role="dialog" aria-modal="true">
        <div class="modal-success-icon" aria-hidden="true">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
        </div>
        <p class="success-badge" id="successBadge">Submitted</p>
        <h3 class="modal-title success-title" id="successModalTitle">Signature submitted</h3>
        <p class="modal-text success-contact mb-0" id="successModalText">
            Your signature has been supplied. We will review it and contact you shortly.
        </p>
        <button type="button" class="btn btn-submit w-100 mt-3" id="closeSuccessModal">OK</button>
    </div>
</div>

@section Scripts {
    <script>
        const signForm = document.getElementById('contractSignForm');
        const signFields = document.getElementById('signFields');
        const changesFields = document.getElementById('changesFields');
        const optionalChangesWrap = document.getElementById('optionalChangesWrap');
        const submitBtn = document.getElementById('submitContractBtn');
        const signFormError = document.getElementById('signFormError');
        const canvas = document.getElementById('signaturePad');
        const ctx = canvas.getContext('2d');
        const successModal = document.getElementById('contractSuccessModal');
        const successTitle = document.getElementById('successModalTitle');
        const successText = document.getElementById('successModalText');
        const successBadge = document.getElementById('successBadge');

        let drawing = false;
        let hasSignature = false;

        function resizeCanvas() {
            const ratio = Math.max(window.devicePixelRatio || 1, 1);
            const rect = canvas.getBoundingClientRect();
            canvas.width = rect.width * ratio;
            canvas.height = rect.height * ratio;
            ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
            ctx.strokeStyle = '#1a1a1b';
            ctx.lineWidth = 2;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
        }

        function getPoint(e) {
            const rect = canvas.getBoundingClientRect();
            const touch = e.touches?.[0] ?? e.changedTouches?.[0];
            const clientX = touch ? touch.clientX : e.clientX;
            const clientY = touch ? touch.clientY : e.clientY;
            return { x: clientX - rect.left, y: clientY - rect.top };
        }

        function startDraw(e) {
            e.preventDefault();
            drawing = true;
            hasSignature = true;
            const p = getPoint(e);
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
        }

        function draw(e) {
            if (!drawing) return;
            e.preventDefault();
            const p = getPoint(e);
            ctx.lineTo(p.x, p.y);
            ctx.stroke();
        }

        function endDraw() {
            drawing = false;
        }

        function clearSignature() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            hasSignature = false;
        }

        canvas.addEventListener('mousedown', startDraw);
        canvas.addEventListener('mousemove', draw);
        canvas.addEventListener('mouseup', endDraw);
        canvas.addEventListener('mouseleave', endDraw);
        canvas.addEventListener('touchstart', startDraw, { passive: false });
        canvas.addEventListener('touchmove', draw, { passive: false });
        canvas.addEventListener('touchend', endDraw);

        document.getElementById('clearSignature')?.addEventListener('click', clearSignature);
        window.addEventListener('resize', () => {
            const data = hasSignature ? canvas.toDataURL('image/png') : null;
            resizeCanvas();
            if (data) {
                const img = new Image();
                img.onload = () => {
                    ctx.drawImage(img, 0, 0, canvas.getBoundingClientRect().width, canvas.getBoundingClientRect().height);
                    hasSignature = true;
                };
                img.src = data;
            }
        });
        resizeCanvas();

        document.querySelectorAll('input[name="submitAction"]').forEach(radio => {
            radio.addEventListener('change', () => {
                const isSign = document.querySelector('input[name="submitAction"]:checked')?.value === 'sign';
                signFields.classList.toggle('d-none', !isSign);
                changesFields.classList.toggle('d-none', isSign);
                optionalChangesWrap.classList.toggle('d-none', !isSign);
                submitBtn.textContent = isSign ? 'Submit signature' : 'Submit changes';
            });
        });

        function showSuccessModal(title, text, badge) {
            successTitle.textContent = title;
            successText.textContent = text;
            successBadge.textContent = badge;
            successModal.classList.add('is-visible');
            successModal.setAttribute('aria-hidden', 'false');
        }

        document.getElementById('closeSuccessModal')?.addEventListener('click', () => {
            successModal.classList.remove('is-visible');
            successModal.setAttribute('aria-hidden', 'true');
        });

        signForm?.addEventListener('submit', async (e) => {
            e.preventDefault();
            signFormError.classList.add('d-none');
            signFormError.textContent = '';

            const action = document.querySelector('input[name="submitAction"]:checked')?.value;
            const tenantName = document.getElementById('tenantName').value.trim();
            const tenantEmail = document.getElementById('tenantEmail').value.trim();
            const tenantPhone = document.getElementById('tenantPhone').value.trim();
            const proposedChanges = document.getElementById('proposedChanges').value.trim();
            const optionalChanges = document.getElementById('optionalChanges').value.trim();

            if (!tenantName || !tenantEmail) {
                signFormError.textContent = 'Name and email are required.';
                signFormError.classList.remove('d-none');
                return;
            }

            if (action === 'sign') {
                if (!document.getElementById('agreeCheckbox').checked) {
                    signFormError.textContent = 'Please confirm that you agree to the terms.';
                    signFormError.classList.remove('d-none');
                    return;
                }
                if (!hasSignature) {
                    signFormError.textContent = 'Please draw your signature.';
                    signFormError.classList.remove('d-none');
                    return;
                }
            } else if (!proposedChanges) {
                signFormError.textContent = 'Describe the changes you are requesting.';
                signFormError.classList.remove('d-none');
                return;
            }

            submitBtn.disabled = true;

            const payload = {
                tenantName,
                tenantEmail,
                tenantPhone: tenantPhone || null,
                action,
                signatureDataUrl: action === 'sign' ? canvas.toDataURL('image/png') : null,
                proposedChanges: action === 'changes'
                    ? proposedChanges
                    : (optionalChanges || null)
            };

            try {
                const response = await fetch(`${window.location.pathname}?handler=Submit`, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                        'RequestVerificationToken': signForm.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify(payload)
                });

                const data = await response.json().catch(() => ({}));

                if (!response.ok) {
                    signFormError.textContent = data.message || 'Something went wrong. Please try again.';
                    signFormError.classList.remove('d-none');
                    submitBtn.disabled = false;
                    return;
                }

                if (action === 'sign') {
                    showSuccessModal(
                        'Signature submitted',
                        'Your signature has been supplied. We will review it and contact you shortly.',
                        'Signature supplied'
                    );
                    clearSignature();
                    document.getElementById('agreeCheckbox').checked = false;
                } else {
                    showSuccessModal(
                        'Changes submitted',
                        'Your proposed changes have been received. We will review them and contact you shortly.',
                        'Changes received'
                    );
                    document.getElementById('proposedChanges').value = '';
                }

                signForm.reset();
                submitBtn.disabled = false;
            } catch {
                signFormError.textContent = 'Something went wrong. Please try again.';
                signFormError.classList.remove('d-none');
                submitBtn.disabled = false;
            }
        });
    </script>
}
